# === 必填（你的設定筆記裡都有）===

# 品牌
SITE_NAME=你的課程名稱
BRAND_NAME=你的品牌名
INSTRUCTOR_NAME=你的名字
PUBLIC_BASE_URL=https://你的網域

# LINE
LINE_CHANNEL_TOKEN=你的 Channel Access Token
LINE_CHANNEL_SECRET=你的 Channel Secret
ADMIN_USER_ID=你的 LINE User ID

# TapPay 金流
TAPPAY_PARTNER_KEY=你的 Partner Key
TAPPAY_MERCHANT_ID=你的 Merchant ID
TAPPAY_APP_ID=你的 App ID
TAPPAY_APP_KEY=你的 App Key
TAPPAY_ENV=sandbox

# Meta 廣告
META_PIXEL_ID=你的 Pixel ID

# === 不用改（系統自動處理）===
# MONGODB_URI=Zeabur 自動注入
