# ===================================================
# AI 造局術 — 環境變數總表
# ===================================================
# 部署流程由 Claude Code 自動處理，不用手動複製。
# 跟 Claude Code 說「幫我部署」即可，它會逐一問你每個值。
# 這份檔案是變數清單參考。
# ===================================================

# === 品牌（必填）===
SITE_NAME=你的課程名稱
BRAND_NAME=你的品牌名
INSTRUCTOR_NAME=你的名字

# === LINE Bot（必填，到 LINE Developers 取得）===
CHANNEL_ACCESS_TOKEN=你的 Channel Access Token
CHANNEL_SECRET=你的 Channel Secret
ADMIN_USER_ID=你的 LINE User ID

# === 網域（部署後自動填入）===
PUBLIC_BASE_URL=https://你的網域
WEB_URL=https://你的網域

# === TapPay 金流（第二階段才設）===
TAPPAY_PARTNER_KEY=
TAPPAY_MERCHANT_ID=
TAPPAY_APP_ID=12348
TAPPAY_APP_KEY=app_pa1pQwXUzaRoMd7svcJawNKgWOBIlBBsIfiPlTZy7ZOiPgCaRKkRGeYRAV1Y
TAPPAY_ENV=sandbox

# === Meta 廣告（第三階段才設）===
META_PIXEL_ID=
META_ACCESS_TOKEN=

# === 系統自動處理（不用動）===
# MONGODB_URI 由 Zeabur 注入
# PORT 由 Zeabur 自動設

