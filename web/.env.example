# ========================================
# Web 課程平台環境變數
# ========================================
# 完整變數清單看 ../.env.example（根目錄那份）
# 這份只列 web service 跑起來需要的
# Claude Code 部署時會自動問你每個值，不用手動填
# ========================================

# 品牌（必填）
SITE_NAME=你的課程名稱
BRAND_NAME=你的品牌名
INSTRUCTOR_NAME=你的名字

# LINE（必填，跟 bot 同一組值）
CHANNEL_ACCESS_TOKEN=your_channel_access_token
CHANNEL_SECRET=your_channel_secret
ADMIN_USER_ID=your_line_user_id

# 網域（部署後自動填）
PUBLIC_BASE_URL=https://your-domain.zeabur.app

# TapPay 金流（第二階段才設，沒填整站還是能跑）
TAPPAY_PARTNER_KEY=your_partner_key
TAPPAY_MERCHANT_ID=your_merchant_id
# 以下是 TapPay 官方公開的 sandbox 測試值，不要改
TAPPAY_APP_ID=12348
TAPPAY_APP_KEY=app_pa1pQwXUzaRoMd7svcJawNKgWOBIlBBsIfiPlTZy7ZOiPgCaRKkRGeYRAV1Y
TAPPAY_ENV=sandbox

# /admin 後台登入密碼（你自己設一個）
DASHBOARD_PASSWORD=your_dashboard_password

# 直播場次範例（格式: MMDD_標籤_YouTube連結）
# SESSION_1=0415_4/15 下午2點_https://youtube.com/live/xxx

# 回放連結範例
# REPLAY_URL=https://youtube.com/watch?v=xxx
